;; added - custom die state that starts the scoutbot explosion sequence
(defstate die (scoutbot)
  :virtual #t
  :event enemy-event-handler
  :enter (behavior ()
    (set-time! (-> self state-time))
    (set! (-> self hit-points) 0.0)
    )
  :code (behavior ()
    (ja-channel-push! 1 (seconds 0.075))
    (let ((f30-0 (rnd-float-range self 0.8 1.2)))
      (ja-no-eval :group! scoutbot-idle-ja :num! (seek! max f30-0) :frame-num 0.0)
      (until (ja-done? 0)
        (suspend)
        (ja :num! (seek! max f30-0))
        )
      )
    (let ((v1-34 (-> self root root-prim)))
      (set! (-> v1-34 prim-core collide-as) (collide-spec))
      (set! (-> v1-34 prim-core collide-with) (collide-spec))
      )
    0
    (while (-> self child)
      (suspend)
      )
    (go-virtual explode)
    )
  :post enemy-simple-post
  )

;; added - custom state for spawning the scoutbot explosion effects and debris 
(defstate explode (scoutbot)
  :virtual #t
  :enter (behavior ()
    (let ((v1-1 (-> self root root-prim)))
      (set! (-> v1-1 prim-core collide-as) (collide-spec))
      (set! (-> v1-1 prim-core collide-with) (collide-spec))
      )
    0
    (logior! (-> self draw status) (draw-control-status no-draw))
    (set! (-> self root root-prim local-sphere w) 491520.0)
    (sound-play "robo-explode")
    )
  :code (behavior ()
    (let ((a1-1 (new 'stack 'debris-tuning (the-as uint 1))))
      (set! (-> a1-1 hit-xz-reaction) 0.95)
      (set! (-> a1-1 hit-y-reaction) 0.6)
      (set! (-> a1-1 scale-rand-lo) 1.9)
      (set! (-> a1-1 scale-rand-hi) 2.6)
      (vector-copy! (-> a1-1 fountain-rand-transv-lo) (-> self incoming attack-position))
      (debris-spawn self a1-1 *scoutbot-debris-params* (the-as process-drawable #f))
      )
    (let ((v1-8 (vector<-cspace! (new 'stack-no-clear 'vector) (joint-node scoutbot-lod0-jg main))))
      (cond
        ((logtest? (-> *part-group-id-table* 1048 flags) (sp-group-flag sp13))
         (vector-copy! (-> *launch-matrix* trans) v1-8)
         (part-tracker-spawn part-tracker-subsampler :to self :group (-> *part-group-id-table* 1048))
         )
        (else
          (vector-copy! (-> *launch-matrix* trans) v1-8)
          (part-tracker-spawn part-tracker :to self :group (-> *part-group-id-table* 1048))
          )
        )
      )
    ;; added - send a 'shutdown' message for the `event-actor` after scoutbot explode
    (let ((a1-2 (new 'stack-no-clear 'event-message-block)))
      (set! (-> a1-2 from) (process->ppointer self))
      (set! (-> a1-2 num-params) 0)
      (set! (-> a1-2 message) 'shutdown)
      (let ((t9-4 send-event-function)
            (v1-22 (-> self event-actor))
            )
        (t9-4
          (if v1-22
              (-> v1-22 extra process)
              )
          a1-2
          )
        )
      )
    (while (-> self child)
      (suspend)
      )
    (cleanup-for-death self)
    )
  )

;; added - implemented an 'event-handler' method
(defmethod event-handler ((this scoutbot) (arg0 process) (arg1 int) (arg2 symbol) (arg3 event-message-block))
  (case arg2
    (('hit 'hit-knocked)
      (when (not (-> this in-ambush?))
        (set! (-> this hit-points) (+ (-> this hit-points) -1.0))
        (cond
          ((<= (-> this hit-points) 0.0)
            (if (not (and (-> this next-state) (= (-> this next-state name) 'die)))
                (go-virtual die)
                )
            )
          (else
            (go (method-of-object this hit))
            )
          )
        )
     #t
     )
    (else
      ((method-of-type nav-enemy event-handler) this arg0 arg1 arg2 arg3)
      )
    )
  )

;; added - override `msg-for-incoming-attack` method from `enemy` type
(defmethod msg-for-incoming-attack ((this scoutbot) (arg0 process) (arg1 event-message-block) (arg2 float))
  "Given an attack message, what do we do next? Returns a message name that should be sent to self."
  (let ((gp-0 (-> this incoming penetrate-using)))
    (cond
      ((and (logtest? (penetrate jak-dark-blackhole) gp-0) #t)
       'go-gun-dark-2-stretch
       )
      ((and (logtest? (penetrate jak-dark-nuke) (-> this incoming penetrate-using)) (can-be-nuked? this))
       'go-gun-dark-3-nuke
       )
      ((and (logtest? gp-0 (-> this penetrate-flinch)) (not (-> this in-ambush?)))
       'hit-flinch
       )
      ((and (logtest? gp-0 (-> this penetrate-knocked)) (not (-> this in-ambush?)))
       'hit-knocked
       )
      (else
        'hit
        )
      )
    )
  )

