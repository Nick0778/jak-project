        (logior! (-> v1-4 flags) (nav-state-flag target-poly-dirty))
        (vector-copy! (-> v1-4 target-pos) gp-0)
        )
      )
    0
    (let ((a0-12 (-> self nav state))
          (v1-8 (-> self dest-pos))
          )
      (logclear! (-> a0-12 flags) (nav-state-flag directional-mode))
      (logior! (-> a0-12 flags) (nav-state-flag target-poly-dirty))
      (vector-copy! (-> a0-12 target-pos) v1-8)
